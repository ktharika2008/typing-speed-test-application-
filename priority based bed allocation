#include <iostream>
#include <queue>
#include <string>
using namespace std;

// Structure to store patient details
struct Patient {
    string name;
    int priority; // higher value = more severe

    // Constructor
    Patient(string n, int p) {
        name = n;
        priority = p;
    }
};

// Comparator for max heap
struct Compare {
    bool operator()(Patient const &p1, Patient const &p2) {
        return p1.priority < p2.priority; // max heap
    }
};

int main() {
    priority_queue<Patient, vector<Patient>, Compare> pq;

    int choice;

    do {
        cout << "\n--- Hospital Bed Allocation System ---\n";
        cout << "1. Add Patient\n";
        cout << "2. Allocate Bed (Highest Priority)\n";
        cout << "3. Display Waiting List\n";
        cout << "4. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        if (choice == 1) {
            string name;
            int priority;

            cout << "Enter patient name: ";
            cin >> name;

            cout << "Enter priority (higher = critical): ";
            cin >> priority;

            pq.push(Patient(name, priority));
            cout << "Patient added successfully!\n";
        }

        else if (choice == 2) {
            if (pq.empty()) {
                cout << "No patients waiting!\n";
            } else {
                Patient p = pq.top();
                pq.pop();
                cout << "Bed allocated to: " << p.name 
                     << " (Priority: " << p.priority << ")\n";
            }
        }

        else if (choice == 3) {
            if (pq.empty()) {
                cout << "No patients in waiting list!\n";
            } else {
                priority_queue<Patient, vector<Patient>, Compare> temp = pq;

                cout << "\nWaiting List:\n";
                while (!temp.empty()) {
                    Patient p = temp.top();
                    cout << p.name << " (Priority: " << p.priority << ")\n";
                    temp.pop();
                }
            }
        }

    } while (choice != 4);

    cout << "Exiting program...\n";
    return 0;
}
